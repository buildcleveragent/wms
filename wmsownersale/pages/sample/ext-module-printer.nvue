<template>
	<div>
		<button type="primary" @click="printManager">原生接口打印</button>
		<button type="primary" @click="setPrinterGray">设置打印机灰度</button>
		<button type="primary" @click="print">打印接口</button>
		<button type="primary" @click="printView">绘图打印接口</button>
		<button type="primary" @click="printTest">打印测试</button>
		<button type="primary" @click="printViewtest">绘图打印测试</button>
		结果：<text> {{textValue}}</text>
	</div>
</template>

<script>
	var main = plus.android.runtimeMainActivity();  
	var receiver;
	// 获取 module 
	var urovoPlatformModule = uni.requireNativePlugin("TH-PlatformSDK-PrinterManager")
	const modal = uni.requireNativePlugin('modal');
	export default {
		data() {
		    return {
		        textValue: ''
		    };
		},
		
		onLoad() {
			console.log('初始化');
 
			var globalEvent = uni.requireNativePlugin('globalEvent');
			globalEvent.addEventListener('rfidEvent', function(e) {
			  console.log('rfidEvent'+JSON.stringify(e));
			});
			var ws = plus.webview.currentWebview();
			plus.key.addEventListener("keydown", function(e) {
				if (e.keyCode == 520 || e.keyCode == 523) {
					console.log("扫描按键触发，键值为 " + e.keyCode);
				 
				}
			})
		},
		methods: {
			testAsyncFunc() {
				// 调用异步方法
				testModule.testAsyncFunc({
						'name': 'unimp',
						'age': 1
					},
					(ret) => {
						modal.toast({
							message: ret,
							duration: 1.5
						});
					})
			},
			testSyncFunc() {
				// 调用同步方法
				var ret = testModule.testSyncFunc({
					'name': 'unimp',
					'age': 1
				})
				modal.toast({
					message: ret,
					duration: 1.5
				});
			},
			gotoNativePage() {
				testModule.gotoNativePage();
			},

			setPrinterGray(){
				urovoPlatformModule.setGrayLevel(6);
				// urovoPlatformModule.setPrinterGray(6)
			},
			printManager(){
						var status = urovoPlatformModule.getStatus();
						console.log("getStatus() status  状态码："+status+"   "+this.getStatus(status));
						
						urovoPlatformModule.setupPage(384,-1);
						var fontSize = 23;
						var fontStyle = 0x0000;
						var fontName = "simsun";
						var height = 1;
						height += urovoPlatformModule.drawTextEx("工业PDA可以在工业要求的严格环境下使用，比如高温，粉尘，湿度等。", 0, height, 384, -1, fontName, fontSize, 0, fontStyle, 0);
						height += urovoPlatformModule.drawTextEx("2工业PDA可以在工业要求的严格环境下使用，比如高温，粉尘，湿度等。", 0, height, 384, -1, fontName, fontSize, 0, fontStyle, 0);
						height += urovoPlatformModule.drawTextEx("3工业PDA可以在工业要求的严格环境下使用，比如高温，粉尘，湿度等。", 0, height, 384, -1, fontName, fontSize, 0, fontStyle, 0);
						urovoPlatformModule.drawBarcode("CGMX1694555995465977857", 0, height, 20, 2, 70, 0);// code128:20   QR-CODE:58
						height += 160;
						
						urovoPlatformModule.drawBarcode("12345678901234567890", 0, height, 58, 7, 180, 0);// code128:20   QR-CODE:58
						height += 160;
				//		Bitmap qrCodeBmp = getQRCodeBitmap("12345678", 20, 160);
				//		Bitmap bitmap = BitmapFactory.decodeResource( context.getResources(), R.mipmap.tmtp2);
				//		height +=printerManager.drawBitmap(bitmap,20,height);
						height +=urovoPlatformModule.drawText("   \n",0,height,fontName,fontSize,true,false,0);//打印空白行
						height +=urovoPlatformModule.drawText("   \n",0,height,fontName,fontSize,true,false,0);//打印空白行
						var ret = urovoPlatformModule.printPage(0);
						console.log("printPage() ret == "+ret+"   "+this.getStatus(ret));
				
				},
				getStatus(event){
					var errmsg = '';
					if(event === 0 ){
						errmsg = "打印正常";
					}else if(event === -1){
						errmsg = "打印机缺纸";
					}else if(event === -2){
						errmsg = "打印机过热";
					}else if(event === -3){
						errmsg = "电量不足";
					}else if(event === -4){
						errmsg = "打印机忙";
					}else if(event === -256){
						errmsg = "打印机错误";
					}else if(event === -257){
						errmsg = "错误驱动程序";
					}
					return errmsg;
					
				},
			print(){
				console.log("接口")
				var printDataList = [] //打印集合
				var printObj = {}
				printObj = {
					'fontTextSize': 30,
					'text':"js打印测试"
				}
				printDataList.push(printObj)
				
				// printObj = {
				// 	'fontTextSize': 25,
				// 	'lineHeight':5,
				// 	'text':"收费标准：前40分钟免费，超出后按累计时长(含前40分钟)计费小型车:1.5元/小时,单日封顶15元中型车:2.0元/小时,单日封顶20元大型车:2.5元/小时,单日封顶25元"
				// }
				// printDataList.push(printObj)
				
				printObj = {
					'fontBold':true,
					'text':"js打印测试 加粗",
				}
				printDataList.push(printObj)
				
				printObj = {}
				printObj = {
					'fontBold':true,
					'text':"js打印测试 加粗 consolas.ttf 字体库",
					'fontName':"/storage/emulated/0/fonts/consolas.ttf"
				}
				printDataList.push(printObj)
				
				printObj = {}
				printObj = {
					'align':1,
					'fontSize':1,
					'text':"js打印测试 居中"
				}
				printDataList.push(printObj)
				
				printObj = {}
				printObj = {
					'align':2,
					'fontSize':1,
					'text':"js打印测试 右对齐"
				}
				printDataList.push(printObj)
				
				printObj = {}
				printObj = {
					'align':3,
					'fontSize':1,
					'lineHeight':15,
					'leftText':"js print 左边",
					'rightText':"js print 右边"
				}
				printDataList.push(printObj)
				
				//左中右
				printObj = {}
				printObj = {
					'align':4,
					'fontSize':1,
					'lineHeight':5,
					'leftText':"js 左边",
					'centerText':"js 中间",
					'rightText':"js 右边"
				}
				printDataList.push(printObj)
				
				//一维码
				printObj = {}
				printObj = {
					'type':1,
					'barcode':"12345678",
					'align':1,
					'width':250,
					'height': 90
				}
				printDataList.push(printObj)
				
				printObj = {}
				printObj = {
					'type':4,
					'feedLineCount': 2
				}
				printDataList.push(printObj)
				
				// //二维码
				printObj = {}
				printObj = {
					'type':2,
					'barcode':"12345678",
					'align':1,
					'offset':25, //X方向上的偏移量
					'height': 300
				}
				printDataList.push(printObj)
				
				// printObj = {
				// 	'type':4,
				// 	'feedLineCount': 2
				// }
				// printDataList.push(printObj)
				
				// printObj = {
				// 	'align':1,
				// 	'fontSize':1,
				// 	'text':"js打印Base64格式图片"
				// }
				// printDataList.push(printObj)
				
				// //打印图片
				// printObj = {}
				// //data:image/jpg;base64,
				// var imageBase64 = ''
				// printObj = {
				// 	'type':3,
				// 	'align':1,
				// 	'imageType':0,
				// 	'imageData':imageBase64,
				// 	'offset':25, //X方向上的偏移量
				// 	"height":200
				// }
				// printDataList.push(printObj)
				
				printObj = {}
				printObj = {
					'type':4,
					'feedLineCount': 2
				}
				printDataList.push(printObj )
				
				var imagePath = '/storage/emulated/0/uniPluginTst.jpg'
				printObj = {}
				printObj = {
					'align':1,
					'fontSize':1,
					'text':"js根据路径打印图片"+imagePath
				}
				printDataList.push(printObj)
				
				//打印图片  
				printObj = {}
				printObj = {
					'type':3,
					'align':1,
					'imageType':1,
					'imageData':imagePath,
					'offset':25, //X方向上的偏移量
					'offsetY':200,//Y方向上的偏移量
					"height":200
				}
				printDataList.push(printObj)
				
				console.log("printDataList " + printDataList.length)
				urovoPlatformModule.startPrint(main,{"printData":printDataList},(ret) => {
					console.log(ret)
					modal.toast({
						message: ret,
						duration: 1.5
					});
				})
				
			},
			printView(){
				console.log("绘图打印接口")
				var printDataList = [] //打印集合
				var printObj = {}
				printObj = {
					'text':"js打印测试"
				}
				printDataList.push(printObj)
				
				printObj = {
					'fontBold':true,
					'text':"js打印测试 加粗"
				}
				printDataList.push(printObj)
				
				printObj = {}
				printObj = {
					'align':1,
					'fontSize':1,
					'text':"js打印测试 居中"
				}
				printDataList.push(printObj)
				
				printObj = {}
				printObj = {
					'align':2,
					'fontSize':1,
					'text':"js打印测试 右对齐"
				}
				printDataList.push(printObj)
				
				printObj = {}
				printObj = {
					'align':3,
					'fontSize':1,
					'lineHeight':15,
					'leftText':"js print 左边",
					'rightText':"js print 右边"
				}
				printDataList.push(printObj)
				
				//左中右
				printObj = {}
				printObj = {
					'align':4,
					'fontSize':1,
					'lineHeight':5,
					'leftText':"js 左边",
					'centerText':"js 中间",
					'rightText':"js 右边"
				}
				printDataList.push(printObj)
				
				console.log("printDataList " + printDataList.length)
				urovoPlatformModule.startPrintPaintView(main,{"printData":printDataList},(ret) => {
					console.log(ret)
					modal.toast({
						message: ret,
						duration: 1.5
					});
				})
			},
			printTest(){
				console.log("打印测试")
				urovoPlatformModule.startPrintTest(main,(ret) => {
					console.log(ret)
					modal.toast({
						message: ret,
						duration: 1.5
					});
				})
			},
			printViewtest(){
				console.log("绘图打印测试")
				urovoPlatformModule.startPrintPaintViewTest(main,(ret) => {
					console.log(ret)
					modal.toast({
						message: ret,
						duration: 1.5
					});
				})
			}
		}
	}
</script>